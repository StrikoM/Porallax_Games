  shiftName: "\u0421\u043C\u0435\u043D\u0430 3"
  directiveText: "\u041F\u0440\u043E\u0432\u0435\u0440\u044F\u0439\u0442\u0435 \u0446\u0432\u0435\u0442
    \u0433\u043B\u0430\u0437. \u041A\u0440\u0430\u0441\u043D\u044B\u0435 = \u041E\u0442\u043A\u0430\u0437."
  hasNewspaper: 1
  newspaperHeadline: "\u041A\u0423\u041B\u042C\u0422 \u041A\u0420\u0410\u0421\u041D\u041E\u0413\u041E
    \u0413\u041B\u0410\u0417\u0410"
  newspaperBody: "\u0420\u0430\u0437\u044B\u0441\u043A\u0438\u0432\u0430\u044E\u0442\u0441\u044F
    \u043E\u043F\u0430\u0441\u043D\u044B\u0435 \u0441\u0435\u043A\u0442\u0430\u043D\u0442\u044B.
    \u041E\u0441\u043E\u0431\u0430\u044F \u043F\u0440\u0438\u043C\u0435\u0442\u0430:
    \u041A\u0420\u0410\u0421\u041D\u042B\u0415 \u0413\u041B\u0410\u0417\u0410. \u0412\u043F\u0443\u0441\u043A\u0430\u0442\u044C
    \u0438\u0445 \u0432 \u0434\u043E\u043C \u0441\u0442\u0440\u043E\u0433\u043E \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043E,
    \u0434\u0430\u0436\u0435 \u0435\u0441\u043B\u0438 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B
    \u0432 \u043F\u043E\u0440\u044F\u0434\u043A\u0435!"
